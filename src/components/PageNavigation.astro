---
import ProgressIndicator from "./ProgressIndicator.astro";
interface Link {
  href: string;
  label?: string;
}
interface Props {
  previous?: Link;
  next?: Link;
  home?: string;
  current?: number;
  total?: number;
}
const { previous, next, home = "/", current, total } = Astro.props;
const hasMedia = Astro.slots.has("media");
---

<aside class="navigation-shell" aria-label="Navegación de la historia">
  {current && total && <ProgressIndicator current={current} total={total} />}
  <nav>
    {
      previous ? (
        <a class="edge previous" href={previous.href} rel="prev">
          <>
            <span aria-hidden="true">←</span>
            <span>{previous.label ?? "Anterior"}</span>
          </>
        </a>
      ) : (
        <span class="edge placeholder" aria-hidden="true" />
      )
    }
    <div class="center-controls">
      <a class="home" href={home} aria-label="Volver al inicio"
        ><span aria-hidden="true">⌂</span><span>Inicio</span></a
      >
      {hasMedia && <slot name="media" />}
    </div>
    {
      next ? (
        <a class="edge next" href={next.href} rel="next">
          <>
            <span>{next.label ?? "Siguiente"}</span>
            <span aria-hidden="true">→</span>
          </>
        </a>
      ) : (
        <span class="edge placeholder" aria-hidden="true" />
      )
    }
  </nav>
</aside>
<style>
  .navigation-shell {
    position: fixed;
    z-index: 50;
    right: 0;
    bottom: 0;
    left: 0;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    border-top: 1px solid var(--color-line);
    box-shadow: 0 -0.5rem 2rem rgb(0 0 0/0.04);
    backdrop-filter: blur(14px);
    padding-bottom: env(safe-area-inset-bottom);
  }
  nav {
    min-height: var(--navigation-height);
    width: min(100%, var(--wide-width));
    margin: auto;
    padding: 0.45rem max(0.75rem, var(--page-gutter));
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.35rem;
  }
  a {
    min-height: 44px;
    padding: 0.45rem 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: var(--radius-small);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 650;
  }
  .edge.next {
    justify-content: flex-end;
    text-align: right;
  }
  .center-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
  }
  .home {
    min-width: 3.5rem;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    color: var(--color-muted);
    font-size: 0.62rem;
  }
  .home span:first-child {
    font-size: 1.1rem;
    line-height: 1;
  }
  .placeholder {
    display: block;
  }
  a:hover {
    background: var(--color-surface-muted);
  }
  @media (max-width: 370px) {
    .edge span:not([aria-hidden]) {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
    }
  }
</style>
