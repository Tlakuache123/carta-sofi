---
interface Props{symbol?:string;label?:string}
const{symbol='·',label}=Astro.props;
---
<div class="divider" role={label?'separator':'presentation'} aria-label={label}><span></span><b aria-hidden="true">{symbol}</b><span></span></div>
<style>.divider{width:min(100%,18rem);margin:auto;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:.8rem;color:var(--color-muted)}.divider span{height:1px;background:var(--color-line)}.divider b{font-size:1.2rem;font-weight:400}</style>
