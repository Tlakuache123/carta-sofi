---
import LetterLayout from "../layouts/LetterLayout.astro";
import LetterPage from "../components/LetterPage.astro";
import StorySection from "../components/StorySection.astro";
import PageNavigation from "../components/PageNavigation.astro";
import RichTextLabel from "../components/RichTextLabel.astro";
import InstantPhoto from "../components/InstantPhoto.astro";
import inicio from "../assets/inicio.jpeg";
import TerminalWindow from "../components/TerminalWindow.astro";
import TypewriterText from "../components/TypewriterText.astro";
---

<LetterLayout
  title="Inicio — Carta para Sofi"
  theme="contrast"
  pageClass="page-home"
>
  <LetterPage label="Inicio">
    <StorySection spacing="large">
      <p class="kicker">Bienvenidos sean, hoy presentamos...</p>
      <RichTextLabel as="h1" text="Una carta para [rainbow]Sofi[/rainbow]" />
      <RichTextLabel
        as="p"
        text={"Hola buenos dias, tardes o noches, este es [shake rate=6 level=2]*se pone nervioso*[/shake] un pequeño detalle para la mujer que me gusta"}
      />
      <InstantPhoto
        src={inicio}
        alt="Retrato de Sofi"
        note="Esta bien guapota Sofi <3"
        aspect="portrait"
        tape
        rotation={3}
      />
      <p class="note">Nota: Al autor le gusta mucho Sofi.</p>
    </StorySection>
    <!-- Insertar tutorial sobre comandos, botones, etc -->
    <StorySection spacing="compact">
      <TerminalWindow title="Tutorial">
        <TypewriterText
          bbcode
          messages={[
            "> Estableciendo conexion[wave]...[/wave]\n> Conexion establecida[wave]...[/wave]\n> Hola [color=#ff8cc8]Sofi[/color]!, haz clic para avanzar al siguiente dialogo",
            "> Durante este tutorial puedes hacer clic en cualquier parte del area central para avanzar al siguiente dialogo.\n> [shake]Vamos hazlo![/shake]",
            "> Abajo encontraras botones para navegar al anterior dialogo\n> O reiniciar la conversacion desde el principio",
            "> [rainbow speed=.5 freq=1.3 sat=.85 val=.65]Fin del tutorial.[/rainbow]\n> Te amo Chofis [color=#ff8cc8]<3[/color]",
          ]}
          speed={32}
          punctuationPause={150}
          advanceOnClick
          clickToSkip
          nextLabel="Toca para continuar ▾"
        />
      </TerminalWindow>
    </StorySection>

    <StorySection align="center" spacing="compact">
      <RichTextLabel
        as="h3"
        text="Asegurate de tener el volumen activado antes de empezar."
      />
      <RichTextLabel
        as="p"
        class="note"
        text="Si no escuchas nada, quizas padezcas de [wave]sordera[/wave] y nunca te diagnosticaron bien"
      />
      <a class="start" href="/carta/1">Comenzar</a>
    </StorySection>

    <PageNavigation next={{ href: "/carta/1", label: "Comenzar" }} />
  </LetterPage>
  <style>
    .kicker {
      color: var(--color-muted);
      font-size: 0.72rem !important;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .start {
      min-height: 48px;
      padding: 0.75rem 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      color: var(--color-accent-contrast);
      background: var(--color-accent);
      border-radius: var(--radius-small);
      text-decoration: none;
      font-weight: 700;
    }
    .marker {
      color: var(--color-muted);
      font: 0.7rem var(--font-mono);
      letter-spacing: 0.15em;
    }
    .note {
      color: var(--color-muted);
      font-size: 0.95rem !important;
    }
  </style>
</LetterLayout>
